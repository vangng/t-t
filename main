<body>

<header>🔥 SHOP ACC FACEBOOK 🔥</header>

<div class="top">
<div>💰 <span id="balance">0</span></div>
<div id="online">0 online</div>
</div>

<div class="container">

<div class="card">
<h3>Tìm kiếm</h3>
<input id="search" placeholder="Nhập..." oninput="searchAcc()">
</div>

<div class="card">
<h3>Danh sách acc</h3>
<div id="list" class="grid"></div>
</div>

<div class="card">
<h3>Lịch sử</h3>
<div id="history"></div>
</div>

<div class="card">
<h3>Log</h3>
<div id="log" class="log"></div>
</div>

</div>

<div class="cart">
<h4>🛒 Giỏ hàng</h4>
<div id="cart"></div>
<button onclick="checkout()">Thanh toán</button>
</div>

<div class="modal" id="login">
<div class="box">
<input id="u" placeholder="User">
<input id="p" placeholder="Pass">
<button onclick="login()">Login</button>
</div>
</div>

<div id="toast" class="toast"></div>

<script>
let balance=0
let accs=[]
let cart=[]
let history=[]
let user=null

/* INIT DATA */
for(let i=1;i<=100;i++){
accs.push({
id:i,
name:"Acc "+i,
price:Math.floor(Math.random()*5000)+1000,
user:"user"+i,
pass:"pass"+i
})
}

/* RENDER */
function render(list){
if(!list) list=accs
let html=""
list.forEach(a=>{
html+=`
<div class="acc">
<h4>${a.name}</h4>
<p>${a.price} VNĐ</p>
<button onclick="addCart(${a.id})">Mua</button>
</div>`
})
document.getElementById("list").innerHTML=html
}

/* SEARCH */
function searchAcc(){
let k=document.getElementById("search").value.toLowerCase()
let f=accs.filter(a=>a.name.toLowerCase().includes(k))
render(f)
}

/* CART */
function addCart(id){
let a=accs.find(x=>x.id==id)
if(!a)return
cart.push(a)
renderCart()
toast("Đã thêm")
}

function renderCart(){
let html=""
cart.forEach(a=>{
html+=`<p>${a.name}</p>`
})
document.getElementById("cart").innerHTML=html
}

/* CHECKOUT */
function checkout(){
let total=cart.reduce((s,a)=>s+a.price,0)
if(balance<total){
alert("Không đủ tiền")
return
}
balance-=total

cart.forEach(a=>{
history.push(a.name+" | "+a.user+" | "+a.pass)
accs=accs.filter(x=>x.id!=a.id)
})

cart=[]
renderCart()
render()
updateHistory()
updateBalance()
toast("Mua thành công")
}

/* HISTORY */
function updateHistory(){
let html=""
history.forEach(h=>{
html+="<p>"+h+"</p>"
})
document.getElementById("history").innerHTML=html
}

/* LOGIN */
setTimeout(()=>{
document.getElementById("login").style.display="flex"
},800)

function login(){
user=document.getElementById("u").value
document.getElementById("login").style.display="none"
log("Login: "+user)
toast("Đăng nhập OK")
}

/* LOG */
function log(t){
let l=document.getElementById("log")
l.innerHTML+="<p>"+t+"</p>"
l.scrollTop=l.scrollHeight
}

/* TOAST */
function toast(t){
let x=document.getElementById("toast")
x.innerText=t
x.style.display="block"
setTimeout(()=>x.style.display="none",1500)
}

/* BALANCE */
function updateBalance(){
document.getElementById("balance").innerText=balance
}

/* AUTO MONEY */
setInterval(()=>{
if(Math.random()>0.7){
let m=Math.floor(Math.random()*2000)
balance+=m
updateBalance()
log("+ "+m)
}
},4000)

/* ONLINE */
setInterval(()=>{
document.getElementById("online").innerText=Math.floor(Math.random()*100)+" online"
},2000)

/* SAVE */
setInterval(()=>{
localStorage.setItem("shop",JSON.stringify({balance,history,accs}))
},3000)

/* LOAD */
window.onload=function(){
let d=localStorage.getItem("shop")
if(d){
d=JSON.parse(d)
balance=d.balance||0
history=d.history||[]
accs=d.accs||accs
updateBalance()
updateHistory()
render()
}else{
render()
}
}
</script>

</body>
</html>
