<script>
let balance=0
let accs=[]
let history=[]

for(let i=1;i<=200;i++){
accs.push({
id:i,
name:"Acc #"+i,
price:Math.floor(Math.random()*5000)+1000,
user:"user"+i,
pass:"pass"+i
})
}

function render(){
let html=""
accs.forEach(a=>{
html+=`
<div class="acc">
<div>
<b>${a.name}</b><br>
${a.price} VNĐ
</div>
<button onclick="buy(${a.id})">Mua</button>
</div>`
})
document.getElementById("list").innerHTML=html
}
render()

function buy(id){
let acc=accs.find(a=>a.id==id)
if(balance<acc.price){
alert("Không đủ tiền")
return
}
balance-=acc.price
document.getElementById("balance").innerText=balance
history.push("Mua "+acc.name+" | "+acc.user+"|"+acc.pass)
updateHistory()
alert("Mua thành công: "+acc.user+" | "+acc.pass)
}

function nap(){
let m=parseInt(document.getElementById("money").value)
if(!m)return
balance+=m
document.getElementById("balance").innerText=balance
history.push("Nạp "+m+" VNĐ")
updateHistory()
}

function updateHistory(){
let html=""
history.forEach(h=>{
html+="<p>"+h+"</p>"
})
document.getElementById("his").innerHTML=html
}

function showTab(id){
document.querySelectorAll(".card").forEach(e=>e.style.display="none")
document.getElementById(id).style.display="block"
}
</script>

